# Wither Launcher - .gitignore

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
build/
dist/
.svelte-kit/
src-tauri/target/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.local
.env.*.local

# Tauri
src-tauri/target/

# Rust
**/*.rs.bk
Cargo.lock

# Package locks (keep one, ignore others)
# pnpm-lock.yaml is kept for consistency
package-lock.json
yarn.lock

# Qwen Code local settings
.qwen/

# Temporary files
tmp/
temp/
*.tmp

# Test coverage
coverage/

# TypeScript cache
*.tsbuildinfo
